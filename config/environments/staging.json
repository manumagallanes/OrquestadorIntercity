{
  "dry_run_default": true,
  "services": {
    "isp": {
      "default_region": "br",
      "regions": {
        "br": {
          "base_url": "https://isp-cube.example.com/api",
          "timeout_seconds": 15.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 4,
            "backoff_initial_seconds": 0.5,
            "backoff_max_seconds": 5.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          }
        },
        "mx": {
          "base_url": "https://mx-isp.example.com/api",
          "timeout_seconds": 15.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 4,
            "backoff_initial_seconds": 0.5,
            "backoff_max_seconds": 5.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          }
        }
      }
    },
    "geogrid": {
      "default_region": "br",
      "regions": {
        "br": {
          "base_url": "https://geogridmaps.example.com/api/v3",
          "timeout_seconds": 20.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 4,
            "backoff_initial_seconds": 0.5,
            "backoff_max_seconds": 6.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          }
        },
        "mx": {
          "base_url": "https://geogridmx.example.com/api/v3",
          "timeout_seconds": 20.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 4,
            "backoff_initial_seconds": 0.5,
            "backoff_max_seconds": 6.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          }
        }
      }
    }
  }
}
