{
  "dry_run_default": true,
  "services": {
    "isp": {
      "default_region": "default",
      "regions": {
        "default": {
          "base_url": "https://ISP_BASE_URL_PLACEHOLDER",
          "timeout_seconds": 12.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 3,
            "backoff_initial_seconds": 0.3,
            "backoff_max_seconds": 5.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          },
          "default_headers": {
            "api-key": "env:ISP_API_KEY",
            "client-id": "env:ISP_CLIENT_ID",
            "login-type": "api",
            "username": "env:ISP_USERNAME",
            "Authorization": "env:ISP_BEARER"
          }
        }
      }
    },
    "geogrid": {
        "default_region": "default",
        "regions": {
          "default": {
            "base_url": "https://GEOGRID_BASE_URL_PLACEHOLDER",
            "timeout_seconds": 30.0,
            "verify_tls": true,
            "retry": {
              "max_attempts": 4,
              "backoff_initial_seconds": 0.4,
              "backoff_max_seconds": 8.0
            },
          "circuit_breaker": {
            "failure_threshold": 3,
            "recovery_timeout_seconds": 60.0
          },
          "default_headers": {
            "api-key": "env:GEOGRID_API_KEY"
          }
        }
      }
    }
  }
}
