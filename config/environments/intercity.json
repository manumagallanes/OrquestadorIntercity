{
  "dry_run_default": true,
  "services": {
    "isp": {
      "default_region": "rio-cuarto",
      "regions": {
        "rio-cuarto": {
          "base_url": "https://api.ispcube.com/v1",
          "timeout_seconds": 12.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 3,
            "backoff_initial_seconds": 0.3,
            "backoff_max_seconds": 5.0
          },
          "circuit_breaker": {
            "failure_threshold": 4,
            "recovery_timeout_seconds": 45.0
          },
          "default_headers": {
            "X-API-Key": "env:ISP_API_KEY"
          }
        }
      }
    },
    "geogrid": {
      "default_region": "rio-cuarto",
      "regions": {
        "rio-cuarto": {
          "base_url": "https://api.geogridmaps.com.br/api/v3",
          "timeout_seconds": 15.0,
          "verify_tls": true,
          "retry": {
            "max_attempts": 4,
            "backoff_initial_seconds": 0.4,
            "backoff_max_seconds": 6.0
          },
          "circuit_breaker": {
            "failure_threshold": 3,
            "recovery_timeout_seconds": 60.0
          },
          "default_headers": {
            "Authorization": "env:GEOGRID_BEARER"
          }
        }
      }
    }
  }
}
