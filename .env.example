# Copiá este archivo a `.env` (o `.env.local`) y ajustá según tu entorno.

# Entorno del orquestador: dev / staging / production
ORCHESTRATOR_ENV=dev

# Overrides opcionales de endpoints (se usan si querés evitar la configuración por JSON)
# Overrides opcionales de endpoints
ISP_BASE_URL=
GEOGRID_BASE_URL=

# Región por servicio (solo si tu entorno JSON define varias regiones)
ISP_REGION=default
GEOGRID_REGION=default

# Otras banderas útiles
DRY_RUN=true
LOG_LEVEL=INFO
ORCHESTRATOR_GEOGRID_AUTO_ATTEND=false
# Para crear la casita automáticamente (requerido por /geogrid/attend)
GEOGRID_PASTA_ID=
# Tipo de cable para el drop (id interno de GeoGrid) o nombre a resolver
GEOGRID_CABO_TIPO_ID=
GEOGRID_CABO_TIPO_NAME=Drop

# Credenciales ISP Cube
ISP_API_KEY=
ISP_CLIENT_ID=
ISP_USERNAME=
ISP_PASSWORD=
ISP_BEARER=

# Credenciales GeoGrid
GEOGRID_API_KEY=
GEOGRID_BEARER=
