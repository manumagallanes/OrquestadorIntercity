# Entorno orientado a las integraciones reales de Intercity.
ORCHESTRATOR_ENV=intercity

# Tokens dummy para pruebas locales. Reemplazalos por los reales cuando los tengas.
ISP_API_KEY=DUMMY_ISP_KEY_123456
GEOGRID_BEARER=Bearer DUMMY_GEOGRID_TOKEN_123456

# Podés forzar dry-run mientras validás el flujo.
DRY_RUN=true
ORCHESTRATOR_GEOGRID_AUTO_ATTEND=false
# Para crear la casita automáticamente (requerido por /geogrid/attend)
GEOGRID_PASTA_ID=
# Tipo de cable para el drop (id interno de GeoGrid) o nombre a resolver
GEOGRID_CABO_TIPO_ID=
GEOGRID_CABO_TIPO_NAME=Drop
