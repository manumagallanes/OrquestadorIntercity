%%{init: {'flowchart': {'useMaxWidth': false, 'curve': 'basis'}}}%%
flowchart LR
    %% ===== Estilos =====
    classDef actor fill:#F4ECF7,stroke:#7D3C98,color:#4A235A,font-weight:bold;
    classDef orchestrator fill:#FDEDEC,stroke:#C0392B,color:#641E16,font-weight:bold;
    classDef system fill:#EBF5FB,stroke:#2471A3,color:#1B4F72;
    classDef mock fill:#F9EBEA,stroke:#B03A2E,color:#78281F,stroke-dasharray:5 3;
    classDef monitor fill:#E8F8F5,stroke:#117864,color:#0E6655;
    classDef storage fill:#FEF9E7,stroke:#B9770E,color:#7D6608;
    classDef note fill:#FDFEFE,stroke:#BFC9CA,color:#5D6D7E,font-size:12px;
    classDef decision fill:#FDF2E9,stroke:#B9770E,color:#7D6608,font-weight:bold;

    %% ===== Actores y herramientas =====
    subgraph Operacion[Operación]
      direction TB
      Operador["Operador / Backoffice"]:::actor
      UI["UI Streamlit (QA)"]:::system
    end

    %% ===== Orquestador =====
    Orchestrator["Intercity Orchestrator<br/>FastAPI + Validaciones + Auditoría"]:::orchestrator

    %% ===== Sistemas reales =====
    subgraph Productivo[Sistemas productivos]
      direction TB
      ISP["ISP-Cube<br/>Catálogo comercial"]:::system
      GeoGrid["GeoGrid<br/>Inventario geoespacial"]:::system
    end

    %% ===== Entorno local (mocks) =====
    subgraph Local[Entorno local / QA]
      direction TB
      ISPMock["isp-mock"]:::mock
      GeoMock["geogrid-mock"]:::mock
    end

    %% ===== Observabilidad y datos internos =====
    subgraph Observabilidad[Observabilidad y analítica]
      direction TB
      Prom["Prometheus"]:::monitor
      Graf["Grafana"]:::monitor
      Datamart["Datamart / Backups<br/>(PostgreSQL, Data Lake, etc.)"]:::storage
    end

    %% ===== Flujos principales =====
    %% ===== Flujos principales =====
    Operador -->|"Operaciones comerciales / tickets"| ISP
    Operador -.->|"Usa UI del orquestador (QA)"| UI
    UI -.->|"Formularios sync / provision / baja"| Orchestrator

    ISP -->|"GET /customers, etc."| Orchestrator
    Orchestrator -->|"Sincronización GeoGrid\n POST/PUT /clientes"| GeoGrid
    Orchestrator -->|"Asignación de puerto\n POST /integracao/atender"| GeoGrid
    Orchestrator -->|"Baja técnica\n DELETE /integracao/atender/{puerto}"| GeoGrid

    Orchestrator --> ISP
    Orchestrator --> GeoGrid

    %% ===== Observabilidad =====
    Orchestrator -->|"Métricas (/metrics)"| Prom
    Prom --> Graf
    Orchestrator -->|"Auditorías (/audits)\nIncidentes (/incidents)"| Graf

    %% ===== Captura de datos internos =====
    Orchestrator -->|"Exports periódicos\n(auditorías, incidentes, métricas)"| Datamart
    subgraph Exportaciones[Extracciones externas]
      direction TB
      ISPExport["Extracción ISP-Cube"]:::system
      GeoExport["Extracción GeoGrid"]:::system
    end
    Productivo -->|"APIs / Reports"| Exportaciones
    Exportaciones -->|"Datos consolidados"| Datamart

    %% ===== Notas =====
    subgraph Notas[Notas]
      direction TB
      Nota1["El orquestador decide si usa mocks locales o servicios productivos según configuración."]:::note
      Nota2["Datamart/backups consolida información propia para reportes y recuperación."]:::note
      Nota3["Prometheus/Grafana monitorean latencias, incidentes y volumen de operaciones."]:::note
    end

    Nota1 -.-> Orchestrator
    Nota1 -.-> Local
    Nota1 -.-> Productivo
    Nota2 -.-> Datamart
    Nota3 -.-> Graf

    linkStyle default stroke:#5D6D7E,stroke-width:1.2px
